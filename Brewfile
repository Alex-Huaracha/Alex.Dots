# ============================================
# Alex.Dots - Brewfile
# ============================================
# Packages installed via Homebrew
# Usage: brew bundle --file=Brewfile
# ============================================

# Shell
brew "zsh"

# Prompt
brew "starship"

# Node.js version manager
brew "fnm"

# Version control
brew "git"
brew "lazygit"

# JSON processor
brew "jq"

# Search tools (useful for editors like nvim)
brew "ripgrep"
brew "fd"

# Terminal multiplexer
brew "tmux"
